# Redis Streams

REDIS_STREAM_CHAT=persist_message_stream

# Redis Pub/Sub

REDIS_CHANNEL_CHAT=chat_channel

# Security — REQUIRED in production
# Generate with: openssl rand -base64 32
JWT_SECRET=
REGISTRATION_SECRET=

# CORS — comma-separated list of allowed origins for WebSocket and REST
CORS_ALLOWED_ORIGINS=https://roasties.it,https://www.roasties.it

# APNs Push Notifications
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_KEY_BASE64=
APNS_BUNDLE_ID=com.danilo.GoMessengeriOS
APNS_ENVIRONMENT=production
